APP_NAME="Liturgia Live"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite

# Untuk MySQL/MariaDB, ganti blok di atas dengan:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=liturgia
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=720

QUEUE_CONNECTION=sync
CACHE_STORE=database
FILESYSTEM_DISK=public

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=liturgia
REVERB_APP_KEY=liturgia-key
REVERB_APP_SECRET=liturgia-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# PIN sederhana untuk halaman kontrol (untuk operator di jaringan lokal)
LITURGIA_PIN=1234
